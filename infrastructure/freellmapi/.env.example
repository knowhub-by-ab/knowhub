# Copy this file to ".env" on the server and fill in the values.
# (Do NOT commit the real .env — it holds your encryption key.)

# Your free DuckDNS domain, e.g. knowhub-ai-api.duckdns.org
DOMAIN=YOURNAME.duckdns.org

# 64-char hex key for encrypting provider keys at rest.
# Generate ONCE on the server with:  openssl rand -hex 32
# Keep it stable forever, or stored provider keys can't be decrypted.
ENCRYPTION_KEY=

# Which website origins may call the API from a browser (comma-separated).
DASHBOARD_ORIGINS=https://knowhub-ai.pages.dev,http://localhost:5173
