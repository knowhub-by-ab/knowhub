# KnowHub environment variables (example). Copy to .env.local and fill in.
# NEVER commit real secrets — only this example file is committed.

# --- Frontend (Vite, must be prefixed with VITE_) ---
# Base URL of the KnowHub API (Cloudflare Worker). Empty = same-origin in dev.
VITE_API_BASE_URL=

# Firebase Web config (public client keys) — added when auth lands (spec 10)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# --- Backend secrets live in the Cloudflare Pages project, NOT here ---
# AI provider keys (GEMINI_API_KEY / GROQ_API_KEY / OPENROUTER_API_KEY / OPENAI_API_KEY),
# GITHUB_OAUTH_CLIENT_ID/SECRET, ENCRYPTION_KEY, etc. are configured as Cloudflare
# Pages secrets (spec 18 §31). See docs/AI_BACKEND_SETUP.md.
